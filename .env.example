# 复制为 .env 并填入真实密钥（.env 不会提交到 git）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# NL 圈人（CDP Agent）：0 = 降级为纯规则模式，不调 LLM
AGENT_LLM_ENABLED=1

# CDP MCP Server（stdio，接入 Claude）
SQL_ENGINE_URL=http://localhost:8002
CDP_TENANT_ID=1001

# CDP API Key 鉴权：sql-engine 校验、MCP/nginx 注入此头。留空 = 关闭鉴权（放行所有请求）。
# 生成：echo "cdp_sk_$(openssl rand -hex 16)"
CDP_API_KEY=
